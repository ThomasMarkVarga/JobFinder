# Copy to .env and tweak. Restart backend after editing.

PORT=5275
MONGODB_URI=mongodb://127.0.0.1:27017/jobfinder

# Headless Chromium options
HEADLESS=true
SCRAPE_TIMEOUT_MS=25000

# Comma-separated list of scrapers to enable. Available: linkedin, indeed, weworkremotely
# Available: linkedin, indeed, weworkremotely, ejobs, bestjobs, google
# Google scrapes regular search results and returns matches from sites NOT
# already covered above — long-tail catch-all (Greenhouse/Lever/Ashby/etc).
SCRAPERS=linkedin,indeed,weworkremotely,ejobs,bestjobs,google
DEBUG_WEB=1

# Cache search results in memory for this many ms (10 min default)
SCRAPE_CACHE_TTL_MS=600000

# Ollama (local LLM). Used for match scoring, gap analysis, cover letters.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b